{
  "$schema": "slot-presets-schema.json",
  "version": "1.0",
  "description": "F&F 매장 신발장 슬롯 프리셋",

  "shelf_configs": {
    "fnf_main_front": {
      "name": "F&F 메인 신발장 (정면)",
      "source_image": "vlm_테스트용/매장/정면.png",
      "total_rows": 6,
      "total_cols": 9,
      "base_shoe_width_px": 120,
      "base_shoe_height_px": 80,
      "perspective": {
        "scale_per_row": 0.03,
        "y_offset_per_row": -2
      },
      "sections": [
        {
          "id": "section_2",
          "file": "2.png",
          "position": "left_corner",
          "cols": [1, 2],
          "has_mask": true,
          "mask_colors": {
            "mint": [0, 255, 200],
            "coral": [255, 100, 100]
          }
        },
        {
          "id": "section_3",
          "file": "3.png",
          "position": "left",
          "cols": [2, 3],
          "has_mask": false
        },
        {
          "id": "section_4",
          "file": "4.png",
          "position": "left_center",
          "cols": [3, 4],
          "has_mask": false
        },
        {
          "id": "section_5",
          "file": "5.png",
          "position": "center",
          "cols": [4, 5, 6],
          "has_mask": false
        },
        {
          "id": "section_6",
          "file": "6.png",
          "position": "right_center",
          "cols": [6, 7],
          "has_mask": false
        },
        {
          "id": "section_7",
          "file": "7.png",
          "position": "right",
          "cols": [7, 8],
          "has_mask": false
        },
        {
          "id": "section_8",
          "file": "8.png",
          "position": "right_corner",
          "cols": [8, 9],
          "has_mask": false
        }
      ]
    }
  },

  "angle_presets": {
    "left_facing": {
      "rotation": -15,
      "description": "좌측 열 - 오른쪽을 향함"
    },
    "center_facing": {
      "rotation": 0,
      "description": "중앙 열 - 정면"
    },
    "right_facing": {
      "rotation": 15,
      "description": "우측 열 - 왼쪽을 향함"
    },
    "three_quarter_left": {
      "rotation": -45,
      "description": "좌측 3/4 뷰"
    },
    "three_quarter_right": {
      "rotation": 45,
      "description": "우측 3/4 뷰"
    }
  },

  "size_presets": {
    "standard": {
      "width": 120,
      "height": 80,
      "description": "표준 운동화 크기"
    },
    "large": {
      "width": 150,
      "height": 100,
      "description": "부츠/하이탑"
    },
    "small": {
      "width": 100,
      "height": 65,
      "description": "슬리퍼/샌들"
    }
  },

  "shadow_presets": {
    "soft": {
      "opacity": 0.2,
      "blur": 8,
      "offset_y": 5,
      "description": "부드러운 그림자"
    },
    "medium": {
      "opacity": 0.3,
      "blur": 5,
      "offset_y": 3,
      "description": "중간 그림자 (권장)"
    },
    "sharp": {
      "opacity": 0.4,
      "blur": 2,
      "offset_y": 2,
      "description": "선명한 그림자"
    },
    "none": {
      "opacity": 0,
      "blur": 0,
      "offset_y": 0,
      "description": "그림자 없음"
    }
  },

  "color_mapping": {
    "description": "마스크 컬러 → 슬롯 타입 매핑",
    "colors": {
      "mint": {
        "rgb": [0, 255, 200],
        "tolerance": 30,
        "slot_type": "left_shoe"
      },
      "coral": {
        "rgb": [255, 100, 100],
        "tolerance": 30,
        "slot_type": "right_shoe"
      },
      "yellow": {
        "rgb": [255, 255, 0],
        "tolerance": 30,
        "slot_type": "center_shoe"
      },
      "blue": {
        "rgb": [100, 100, 255],
        "tolerance": 30,
        "slot_type": "highlight_shoe"
      }
    }
  },

  "default_config": {
    "mapping_mode": "sequential",
    "allow_duplicates": false,
    "shadow_preset": "medium",
    "angle_auto_adjust": true,
    "size_auto_adjust": true,
    "output_format": "png",
    "output_quality": 95
  },

  "validation_thresholds": {
    "size_consistency_min": 80,
    "angle_consistency_min": 70,
    "position_accuracy_min": 90,
    "composite_quality_min": 75,
    "overall_pass_min": 85
  }
}
