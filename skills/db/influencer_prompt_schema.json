      "장소": {"required": true, "note": "구체적인 장소 설명 (이미지 안 보고도 이해할 수 있도록)"},
      "분위기": {"required": false, "examples": ["힙하고 모던한", "인더스트리얼", "낭만적인", "캐주얼한"]},
