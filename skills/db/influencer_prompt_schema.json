  "field_rules": {
    "모델": {
      "국적": {"required": true, "default": "한국인", "options": ["한국인", "일본인", "중국인", "동남아시아인", "서양인"]},
      "성별": {"required": true, "default": "여성", "options": ["여성", "남성"]},
      "나이": {"required": false, "default": "20대 초반", "options": ["10대 후반", "20대 초반", "20대 중반", "20대 후반", "30대 초반"]}
    },

    "헤어": {
      "스타일": {"required": false, "default": "straight_loose", "options": ["straight_loose", "wavy", "ponytail", "bun", "braids", "short_bob"]},
      "컬러": {"required": false, "default": "dark_brown", "options": ["black", "dark_brown", "brown", "blonde", "red", "ash_gray"]},
      "질감": {"required": false, "default": "sleek", "options": ["sleek", "voluminous", "textured", "messy"]}
    },

    "표정": {
      "preset_id": {"required": false, "note": "expression_presets.json의 ID 참조 (예: 시크_02, 러블리_03)"},
      "베이스": {"required": true, "default": "cool", "options": ["cool", "natural", "dreamy", "playful", "cute"]},
      "눈": {"required": false, "note": "프리셋에서 자동 로드. 예: '큰 눈, 무심한 쿨 눈빛'"},
      "시선": {"required": false, "default": "정면", "options": ["정면", "왼쪽", "오른쪽", "아래", "3/4 측면"]},
      "입": {"required": false, "default": "다문", "options": ["다문", "살짝 벌림", "살짝 벌림(2mm)", "살짝 벌림(3mm)", "살짝 벌림(5mm)", "살짝 미소", "살짝 삐죽", "벌림"]},
      "얼굴각도": {"required": false, "default": "정면", "options": ["정면", "3/4 오른쪽", "3/4 왼쪽", "측면"]},
      "턱": {"required": false, "default": "자연스러운", "options": ["자연스러운", "들어올린", "내린"]},
      "is_wink": {"required": false, "default": false, "type": "boolean", "note": "윙크 여부"},
      "wink_eye": {"required": false, "default": "", "options": ["left", "right"], "note": "is_wink=true일 때 어느 눈으로 윙크하는지"}
    },

    "포즈": {
      "preset_id": {"required": false, "note": "pose_presets.json의 ID 참조 (예: 전신_05, 상반신_12, 앉기_07)"},
      "stance": {"required": true, "options": ["stand", "lean_wall", "sit", "walk", "kneel", "lean"]},
      "왼팔": {"required": true, "type": "object", "fields": {
        "설명": {"required": true, "note": "팔 전체 동작 설명"},
        "손": {"required": true, "note": "손 동작/위치"},
        "팔꿈치각도": {"required": false, "note": "예: '약 90도'"},
        "팔꿈치방향": {"required": false, "note": "예: '바깥쪽', '아래쪽', '뒤쪽'"}
      }},
      "오른팔": {"required": true, "type": "object", "fields": {
        "설명": {"required": true},
        "손": {"required": true},
        "팔꿈치각도": {"required": false},
        "팔꿈치방향": {"required": false}
      }},
      "왼다리": {"required": true, "type": "object", "fields": {
        "설명": {"required": true, "note": "다리 전체 동작 설명"},
        "무릎각도": {"required": true, "note": "예: '약 175도 (거의 펴짐)'"},
        "무릎방향": {"required": true, "note": "예: '정면', '바깥쪽으로 벌어짐'"},
        "무릎높이": {"required": false, "note": "앉기 포즈에서 중요. 예: '가슴 높이'"},
        "발방향": {"required": true, "note": "예: '정면', '바깥쪽 30도'"},
        "발위치": {"required": true, "note": "예: '엉덩이에서 약 40cm 앞'"}
      }},
      "오른다리": {"required": true, "type": "object", "fields": {
        "설명": {"required": true},
        "무릎각도": {"required": true},
        "무릎방향": {"required": true},
        "무릎높이": {"required": false},
        "발방향": {"required": true},
        "발위치": {"required": true}
      }},
      "힙": {"required": true, "type": "object", "fields": {
        "설명": {"required": true, "note": "무게중심 설명"},
        "상체기울기": {"required": true, "note": "예: '오른쪽으로 약 10도 기울임'"}
      }},
      "어깨라인": {"required": true, "note": "어깨 높낮이. 예: '오른쪽 어깨가 왼쪽보다 낮음'"},
      "얼굴방향": {"required": true, "note": "얼굴이 향하는 방향. 예: '카메라 정면', '오른쪽으로 45도 돌림'"},
      "다리형태": {"required": false, "options": ["4자", "L자", "직립"], "note": "구부린 다리 형태. 4자=무릎 옆으로, L자=무릎 앞으로"},
      "촬영": {"required": false, "type": "object", "note": "포즈 프리셋에 내장된 촬영 정보 (VLM 분석 결과)", "fields": {
        "앵글": {"required": false, "options": ["정면", "약간측면", "측면"], "note": "카메라 앵글"},
        "높이": {"required": false, "options": ["눈높이", "살짝로앵글", "로앵글", "하이앵글"], "note": "카메라 높이"},
        "프레이밍": {"required": false, "options": ["FS", "MFS", "MS", "MCU", "CU"], "note": "프레이밍"}
      }}
    },

    "배경": {
      "preset_id": {"required": false, "note": "background_presets.json의 ID 참조 (예: 핫플카페_08, 그래피티_03)"},
