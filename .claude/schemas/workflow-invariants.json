  "workflows": {

    "brand_cut": {
      "category": "person",
      "description": "브랜드 화보 생성 - 착장 정확도가 생명",
      "core_invariants": [
        {
          "id": "outfit_accuracy",
          "name": "착장 정확도",
          "description": "착장 색상, 로고, 디테일이 실제 상품과 100% 일치해야 함. 색상 틀리면 상품 클레임, 로고 누락되면 브랜드 노출 실패.",
          "priority": 1,
          "verification_method": "vlm_comparison",
          "prompt_keywords": ["exact outfit colors", "preserve logo", "maintain garment details", "accurate fabric texture"],
          "fail_threshold": 70,
          "business_impact": "상품 오인 -> 고객 클레임 -> 브랜드 신뢰도 하락"
        },
        {
          "id": "face_identity",
          "name": "얼굴 동일성",
          "description": "모델 얼굴이 원본과 동일해야 함. 다른 사람 얼굴이면 초상권 문제 발생.",
          "priority": 2,
          "verification_method": "vlm_comparison",
          "prompt_keywords": ["preserve face identity", "same person", "maintain facial features"],
          "fail_threshold": 70,
          "business_impact": "모델 계약 위반 -> 법적 리스크"
        },
        {
          "id": "brand_tone",
          "name": "브랜드 톤",
          "description": "브랜드 DNA에 맞는 톤앤매너. MLB는 쿨/스트릿, Discovery는 아웃도어/자연.",
          "priority": 3,
          "verification_method": "vlm_analysis",
          "prompt_keywords": ["brand aesthetic", "brand mood"],
          "fail_threshold": 65,
          "business_impact": "브랜드 이미지 불일치 -> 마케팅 효과 저하"
        }
      ],
      "preservation_rules": {
        "must_change": ["배경", "조명", "구도"],
        "must_preserve": ["착장 색상/로고/디테일", "얼굴 identity", "체형 비율"],
        "flexible": ["포즈 세부사항", "표정 강도", "배경 소품"]
      },
      "validation_requirements": {
        "required_gates": ["outfit_gate", "face_gate", "brand_tone_gate", "anatomy_gate", "quality_gate"],
        "auto_fail_conditions": [
          "착장 색상 불일치",
          "로고 누락 또는 변형",
          "얼굴 다른 사람",
          "손가락 6개 이상",
          "누런 톤 (warm cast)",
          "의도하지 않은 텍스트"
        ],
        "min_pass_score": 85
      },
      "enhancement_requirements": {
        "on_invariant_fail": [
          {"invariant": "outfit_accuracy", "enhancement": "착장 관련 프롬프트 가중치 2배, 색상 hex 코드 명시"},
          {"invariant": "face_identity", "enhancement": "얼굴 보존 키워드 추가, 얼굴 이미지 우선순위 상향"},
          {"invariant": "brand_tone", "enhancement": "브랜드 금지 키워드 네거티브 프롬프트에 추가"}
